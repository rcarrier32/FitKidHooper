# Copy to .env.local for local dev, and add the same secrets to GitHub Actions
# for production builds (Settings → Secrets → Actions).

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Optional: protect admin dashboard (?admin=YOUR_KEY). Omit to use ?admin=1 in dev.
VITE_ADMIN_DASHBOARD_KEY=

# Optional: stamped into analytics events (defaults to "dev" locally).
VITE_APP_VERSION=dev

# Optional: Legends YBA donation link (Zeffy campaign). Omit to hide the
# "Support Legends Youth Basketball" card in Settings entirely.
VITE_DONATE_URL=

# Legends eligibility check endpoint (gates FKH access to Legends athletes / invite codes)
VITE_LEGENDS_VERIFY_URL=https://www.legendsyba.com/api/fkh/verify

# How that gate behaves. Defaults to "warn" — it checks and logs but never blocks.
# Only set "block" once real family emails come back eligible; until the Legends
# roster is populated, blocking turns away 100% of new signups. "off" skips it.
VITE_LEGENDS_GATE_MODE=warn
